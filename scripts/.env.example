# CrankReview Environment Configuration
# Rename this file to '.env' and fill in your details.

# 1. Your JSON Feed URL (e.g., from Micro.blog or a personal site)
FEED_URL="https://your-blog-url.com/feed.json"

# 2. The full path to your Obsidian Vault folder where you want reviews saved
VAULT_DIR="/Users/yourname/Documents/ObsidianVault/CrankReviews"

# 3. Your Gemini API Key (if required by your gemini CLI setup)
GEMINI_API_KEY="your_api_key_here"

# 4. Optional: Custom prompt overrides or model settings can go here